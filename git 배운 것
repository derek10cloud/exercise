$ git init #현재 위치 디렉토리(=작업 트리=워킹 디렉토리)에서 git 사용가능하게 함
$ git remote add origin <레포지토리 URL> #해당 레포지토리로 원격 연결
$ git status #git 상태 확인
$ git add <파일이름 또는 ./> #변경 사항 있는 파일 또는 현재 디렉토리의 모든 파일 push할 준비 시킴 (= 수정한 파일을 작업트리에서 스테이지로 스테이징하기)
$ git commit -m "<커밋 메세지>" #푸시 전 커밋 메세지 작성 (= 새로운 버전이 생성되면서 로컬 저장소에 저장된다.)
$ git push origin <현재 브랜치> #연결되어 있는 레포지토리의 브랜치로 변경 사항 전송
$ git branch <신규 브랜치 이름> #신규 브랜치 생성
$ git branch #생성된 브랜치와 현재 위치 브랜치 확인
$ git checkout <브랜치 이름> #작업할 브랜치 변경
$ git pull origin <브랜치 이름> #<브랜치 이름>에서의 코드를 현재 작업할 브랜치에 다 불러 옴
------------예시--------------
$ git pull origin master #master 브랜치의 코드들을 현재 브랜치에 불러옴
$ 코드 수정
$ git add ./
$ git commit -m "<커밋 메세지>"
$ git push origin <현재 브랜치>
$ git checkout master #작업 브랜치를 master branch로 변경
-----------------------------
$ git merge <머지할 브랜치> #머지할 브랜치에 있는 코드를 현재 브랜치로 머지한다. (마스터에 접속해서 다른 사람의 브랜치를 머지할 수 있음)
$ git push #머지한 브랜치를 푸쉬해서 코드를 병합
$ git log #지금까지 커밋했던 기록을 살펴볼 수 있음
$ git diff #작업트리vs스테이지 또는 스테이지vs저장소 차이 확인
$ git log --oneline --branches --graph #그동안의 깃 브랜치 히스토리 확인
$ git log master..apple #왼쪽 브랜치(master)와 비교했을 때, 오른쪽 브랜치(apple)가 뭐가 달라졌는 지 확인

> 커밋 해시, 깃 해시 : 커밋을 구별하는 아이디
